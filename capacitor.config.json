{
  "appId": "com.theexecutive.app",
  "appName": "The Executive",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "ios": {
    "scheme": "The Executive",
    "backgroundColor": "#080808",
    "contentInset": "automatic",
    "scrollEnabled": true,
    "limitsNavigationsToAppBoundDomains": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#080808",
      "spinnerColor": "#C9A84C",
      "showSpinner": true,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#080808"
    },
    "Keyboard": {
      "resize": "body",
      "style": "dark",
      "resizeOnFullScreen": true
    }
  }
}
