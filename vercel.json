{
  "functions": {
    "api/*.js": { "memory": 256, "maxDuration": 30 }
  },
  "routes": [
    { "src": "/api/claude", "dest": "/api/claude.js" },
    { "src": "/api/quote", "dest": "/api/quote.js" },
    { "src": "/api/news", "dest": "/api/news.js" },
    { "src": "/api/stripe-create-checkout", "dest": "/api/stripe-create-checkout.js" },
    { "src": "/api/stripe-webhook", "dest": "/api/stripe-webhook.js" },
    { "src": "/api/stripe-portal", "dest": "/api/stripe-portal.js" },
    { "src": "/app/(.*)", "dest": "/index.html" },
    { "src": "/app", "dest": "/index.html" },
    { "src": "/", "dest": "/landing/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite"
}
